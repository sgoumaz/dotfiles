# Reference: https://github.com/koekeishiya/yabai/wiki/Configuration#configuration-file

# config

yabai -m config layout bsp \
                window_gap 2 \
                top_padding 0 \
                bottom_padding 0 \
                left_padding 0 \
                right_padding 0 \
                window_placement second_child \
                mouse_drop_action stack \
                mouse_follows_focus off \
                window_opacity_duration 100
# yabai -m config debug_output on

# Rules & signals
# doc: https://github.com/koekeishiya/yabai/blob/master/doc/yabai.asciidoc

yabai -m rule --add app="^Ghostty$" display=^1
yabai -m rule --add app="^Ghostty$" native-fullscreen=on
yabai -m rule --add app="^VSCodium$" display=^1
yabai -m rule --add app="^VSCodium$" native-fullscreen=on
yabai -m rule --add app="^Obsidian$" display=^1
yabai -m rule --add app="^GoodTask$" display=^2
yabai -m rule --add app="^MailMate$" display=^2
yabai -m rule --add app="^Signal$" display=^2
yabai -m rule --add app="^WhatsApp$" display=^2

yabai -m rule --add app="^LaunchBar$" manage=off
yabai -m rule --add app="^digikam$" title="^Fuji Fujifilm X100V$" manage=off
yabai -m rule --add app="^Finder$" title="^Copier$" manage=off
yabai -m rule --add app="^Firefox$" title="^Ouverture de" manage=off
yabai -m rule --add app="^Hammerspoon$" manage=off
yabai -m rule --add app="^Réglages Système$" manage=off

# signals

# flash focused window (cf. Yabai wiki) - requires disabling SIP
# yabai -m signal --add label="flash_focus" event="window_focused" action="yabai -m window \$YABAI_WINDOW_ID --opacity 0.1 && sleep $(yabai -m config window_opacity_duration) && yabai -m window \$YABAI_WINDOW_ID --opacity 0.0"
